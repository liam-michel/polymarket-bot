// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client  {
  provider = "prisma-kysely"
  output  = "../src/__generated__/"
  fileName = "database.ts"
}
datasource db {
  provider = "postgresql"
}

//  Categories
enum Category { 
  Politics
  Geopolitics
  GlobalPolitics
  Crypto
  Sports
  Finance
  Economics
  Tech
  Culture
  Weather
  Mentions
  Science
  Other

}
// ─── Markets ─────────────────────────────────────────────────────────────────

model Market {
  condition_id  String       @id @map("condition_id")
  question      String
  category      Category?
  outcome_a     String       @map("outcome_a")
  outcome_b     String       @map("outcome_b")
  token_a_id   String?      @map("token_a_id")
  token_b_id   String?      @map("token_b_id")
  status        MarketStatus @default(ACTIVE)
  outcome       Int?
  closes_at     DateTime     @map("closes_at")
  resolved_at   DateTime?    @map("resolved_at")
  volume_usd    Decimal      @default(0) @map("volume_usd") @db.Decimal(18, 2)
  created_at    DateTime     @default(now()) @map("created_at")
  updated_at    DateTime     @updatedAt @map("updated_at")

  trades        Trade[]
  positions     Position[]
  prices        MarketPrice[]
  signals       Signal[]

  @@map("markets")
}

enum MarketStatus {
  ACTIVE
  CLOSED
  RESOLVED

  @@map("market_status")
}

// ─── Trades ──────────────────────────────────────────────────────────────────

model Trade {
  fill_id       String    @id @map("fill_id")
  condition_id  String    @map("condition_id")
  wallet        String
  side          TradeSide
  outcome_index Int       @map("outcome_index")
  price         Decimal   @db.Decimal(10, 6)
  size          Decimal   @db.Decimal(18, 6)
  usd_value     Decimal   @map("usd_value") @db.Decimal(18, 2)
  filled_at     DateTime  @map("filled_at")
  created_at    DateTime  @default(now()) @map("created_at")

  market        Market    @relation(fields: [condition_id], references: [condition_id])

  @@index([wallet])
  @@index([condition_id])
  @@index([filled_at])
  @@index([wallet, filled_at])
  @@map("trades")
}

enum TradeSide {
  BUY
  SELL

  @@map("trade_side")
}

// ─── Positions ────────────────────────────────────────────────────────────────
// Snapshot — overwritten on each poll, not append-only

model Position {
  id            Int      @id @default(autoincrement())
  wallet        String
  condition_id  String   @map("condition_id")
  outcome_index Int      @map("outcome_index")
  size          Decimal  @db.Decimal(18, 6)
  avg_entry     Decimal  @map("avg_entry") @db.Decimal(10, 6)
  current_price Decimal  @map("current_price") @db.Decimal(10, 6)
  unrealised_pnl Decimal @map("unrealised_pnl") @db.Decimal(18, 2)
  updated_at    DateTime @updatedAt @map("updated_at")

  market        Market   @relation(fields: [condition_id], references: [condition_id])

  @@unique([wallet, condition_id, outcome_index])
  @@index([wallet])
  @@map("positions")
}

// ─── Trader stats ─────────────────────────────────────────────────────────────

model TraderStats {
  wallet          String   @id
  trade_count     Int      @default(0) @map("trade_count")
  resolved_trades Int      @default(0) @map("resolved_trades")
  win_count       Int      @default(0) @map("win_count")
  win_rate        Decimal  @default(0) @map("win_rate") @db.Decimal(6, 4)
  realised_pnl    Decimal  @default(0) @map("realised_pnl") @db.Decimal(18, 2)
  roi             Decimal  @default(0) @db.Decimal(10, 4)
  avg_edge        Decimal  @default(0) @map("avg_edge") @db.Decimal(10, 6)
  score           Decimal  @default(0) @db.Decimal(10, 4)
  first_trade_at  DateTime? @map("first_trade_at")
  last_trade_at   DateTime? @map("last_trade_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  @@map("trader_stats")
}

// ─── Market prices ────────────────────────────────────────────────────────────
// Time-series — consider TimescaleDB hypertable for this table

model MarketPrice {
  id            BigInt   @id @default(autoincrement())
  condition_id  String   @map("condition_id")
  outcome_index Int      @map("outcome_index")
  price         Decimal  @db.Decimal(10, 6)
  captured_at   DateTime @map("captured_at")

  market        Market   @relation(fields: [condition_id], references: [condition_id])

  @@index([condition_id, outcome_index, captured_at])
  @@map("market_prices")
}

// ─── Watchlist ────────────────────────────────────────────────────────────────

model Watchlist {
  wallet     String   @id
  reason     String
  score      Decimal  @db.Decimal(10, 4)
  active     Boolean  @default(true)
  added_at   DateTime @default(now()) @map("added_at")
  removed_at DateTime? @map("removed_at")

  @@map("watchlist")
}

// ─── Signal log ───────────────────────────────────────────────────────────────

model Signal {
  id            BigInt     @id @default(autoincrement())
  wallet        String
  condition_id  String     @map("condition_id")
  signal_type   SignalType @map("signal_type")
  side          TradeSide
  outcome_index Int        @map("outcome_index")
  price         Decimal    @db.Decimal(10, 6)
  confidence    Decimal    @db.Decimal(6, 4)
  dry_run       Boolean    @default(true) @map("dry_run")
  executed      Boolean    @default(false)
  executed_at   DateTime?  @map("executed_at")
  notes         String?
  created_at    DateTime   @default(now()) @map("created_at")

  market        Market     @relation(fields: [condition_id], references: [condition_id])

  @@index([wallet])
  @@index([created_at])
  @@map("signals")
}

enum SignalType {
  COPY_TRADE
  PATTERN_MATCH
  MANUAL

  @@map("signal_type")
}

// ─── Ingestion cursors ────────────────────────────────────────────────────────

model IngestionCursor {
  key        String   @id
  cursor     String
  updated_at DateTime @updatedAt @map("updated_at")

  @@map("ingestion_cursors")
}