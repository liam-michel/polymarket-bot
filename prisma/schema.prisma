// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client  {
  provider = "prisma-kysely"
  output  = "../src/__generated__/"
  fileName = "database.ts"
}
datasource db {
  provider = "postgresql"
}
// ─── Markets ─────────────────────────────────────────────────────────────────

model Market {
  conditionId   String       @id @map("condition_id")
  question      String
  category      String?
  outcomeA      String       @map("outcome_a")
  outcomeB      String       @map("outcome_b")
  status        MarketStatus @default(ACTIVE)
  outcome       Int?
  closesAt      DateTime     @map("closes_at")
  resolvedAt    DateTime?    @map("resolved_at")
  volumeUsd     Decimal      @default(0) @map("volume_usd") @db.Decimal(18, 2)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  trades        Trade[]
  positions     Position[]
  prices        MarketPrice[]
  signals       Signal[]

  @@map("markets")
}

enum MarketStatus {
  ACTIVE
  CLOSED
  RESOLVED

  @@map("market_status")
}

// ─── Trades ──────────────────────────────────────────────────────────────────

model Trade {
  fillId        String    @id @map("fill_id")
  conditionId   String    @map("condition_id")
  wallet        String
  side          TradeSide
  outcomeIndex  Int       @map("outcome_index")
  price         Decimal   @db.Decimal(10, 6)
  size          Decimal   @db.Decimal(18, 6)
  usdValue      Decimal   @map("usd_value") @db.Decimal(18, 2)
  filledAt      DateTime  @map("filled_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  market        Market    @relation(fields: [conditionId], references: [conditionId])

  @@index([wallet])
  @@index([conditionId])
  @@index([filledAt])
  @@index([wallet, filledAt])
  @@map("trades")
}

enum TradeSide {
  BUY
  SELL

  @@map("trade_side")
}

// ─── Positions ────────────────────────────────────────────────────────────────
// Snapshot — overwritten on each poll, not append-only

model Position {
  id            Int      @id @default(autoincrement())
  wallet        String
  conditionId   String   @map("condition_id")
  outcomeIndex  Int      @map("outcome_index")
  size          Decimal  @db.Decimal(18, 6)
  avgEntry      Decimal  @map("avg_entry") @db.Decimal(10, 6)
  currentPrice  Decimal  @map("current_price") @db.Decimal(10, 6)
  unrealisedPnl Decimal  @map("unrealised_pnl") @db.Decimal(18, 2)
  updatedAt     DateTime @updatedAt @map("updated_at")

  market        Market   @relation(fields: [conditionId], references: [conditionId])

  @@unique([wallet, conditionId, outcomeIndex])
  @@index([wallet])
  @@map("positions")
}

// ─── Trader stats ─────────────────────────────────────────────────────────────

model TraderStats {
  wallet         String   @id
  tradeCount     Int      @default(0) @map("trade_count")
  resolvedTrades Int      @default(0) @map("resolved_trades")
  winCount       Int      @default(0) @map("win_count")
  winRate        Decimal  @default(0) @map("win_rate") @db.Decimal(6, 4)
  realisedPnl    Decimal  @default(0) @map("realised_pnl") @db.Decimal(18, 2)
  roi            Decimal  @default(0) @db.Decimal(10, 4)
  avgEdge        Decimal  @default(0) @map("avg_edge") @db.Decimal(10, 6)
  score          Decimal  @default(0) @db.Decimal(10, 4)
  firstTradeAt   DateTime? @map("first_trade_at")
  lastTradeAt    DateTime? @map("last_trade_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("trader_stats")
}

// ─── Market prices ────────────────────────────────────────────────────────────
// Time-series — consider TimescaleDB hypertable for this table

model MarketPrice {
  id           BigInt   @id @default(autoincrement())
  conditionId  String   @map("condition_id")
  outcomeIndex Int      @map("outcome_index")
  price        Decimal  @db.Decimal(10, 6)
  capturedAt   DateTime @map("captured_at")

  market       Market   @relation(fields: [conditionId], references: [conditionId])

  @@index([conditionId, outcomeIndex, capturedAt])
  @@map("market_prices")
}

// ─── Watchlist ────────────────────────────────────────────────────────────────

model Watchlist {
  wallet    String   @id
  reason    String
  score     Decimal  @db.Decimal(10, 4)
  active    Boolean  @default(true)
  addedAt   DateTime @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")

  @@map("watchlist")
}

// ─── Signal log ───────────────────────────────────────────────────────────────

model Signal {
  id           BigInt     @id @default(autoincrement())
  wallet       String
  conditionId  String     @map("condition_id")
  signalType   SignalType @map("signal_type")
  side         TradeSide
  outcomeIndex Int        @map("outcome_index")
  price        Decimal    @db.Decimal(10, 6)
  confidence   Decimal    @db.Decimal(6, 4)
  dryRun       Boolean    @default(true) @map("dry_run")
  executed     Boolean    @default(false)
  executedAt   DateTime?  @map("executed_at")
  notes        String?
  createdAt    DateTime   @default(now()) @map("created_at")

  market       Market     @relation(fields: [conditionId], references: [conditionId])

  @@index([wallet])
  @@index([createdAt])
  @@map("signals")
}

enum SignalType {
  COPY_TRADE
  PATTERN_MATCH
  MANUAL

  @@map("signal_type")
}

// ─── Ingestion cursors ────────────────────────────────────────────────────────

model IngestionCursor {
  key       String   @id
  cursor    String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ingestion_cursors")
}