{
  "name": "polymarket-bot",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./src/app.ts",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "codegen": "prisma generate",
    "startcli": "bun run ./src/cli/index.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "ci:autofix": "bun run lint:fix && bun run format",
    "ci:quality": "bun run typecheck && bun run lint && bun run format:check",
    "ci:verify": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "db:dev": "docker compose --env-file .env.dev up -d",
    "migrate:dev": "dotenv -e .env.dev -- prisma migrate dev"
  },
  "devDependencies": {
    "@types/decimal.js": "^7.4.3",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "prisma-kysely": "^3.1.0",
    "testdouble": "^3.20.2",
    "typescript": "^5.1.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "commander": "^14.0.3",
    "decimal.js": "^10.6.0",
    "kysely": "^0.28.14",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "radashi": "^12.7.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
