{
  "compilerOptions": {
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["node"],
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "include": ["src", "prisma", "*.ts"]
}
